SECRET_KEY=your_key_here
DEBUG=True
DASHBOARD_URL=http://localhost:5173

# Database
POSTGRES_DB=cvsentry_db
POSTGRES_USER=your_db_username
POSTGRES_PASSWORD=your_db_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Email (SMTP)
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# MinIO (S3-compatible storage for recordings)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeMeMinIO
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=cvsentry-recordings

# SRS (Simple Realtime Server — cloud relay + recording)
SRS_CANDIDATE=127.0.0.1
SRS_API_PASSWORD=changeMeSRS
SRS_WHEP_TOKEN_SECRET=your_whep_signing_secret
SRS_WHEP_TOKEN_TTL_SECONDS=30

# Recording retention (days, 0 = keep forever)
RECORDING_RETENTION_DAYS=7
