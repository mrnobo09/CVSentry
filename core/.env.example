SECRET_KEY=your_key_here
DEBUG=True
DASHBOARD_URL=http://localhost:5173

# Database
POSTGRES_DB=cvsentry_db
POSTGRES_USER=your_db_username
POSTGRES_PASSWORD=your_db_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Email (SMTP)
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# MinIO (S3-compatible storage for recordings)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeMeMinIO
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=cvsentry-recordings

# SRS (Simple Realtime Server — cloud relay + recording)
# Replace <YOUR_AZURE_IP> with your public server IP or domain
SRS_CANDIDATE=<YOUR_AZURE_IP>
SRS_EXTERNAL_WHIP_URL=http://<YOUR_AZURE_IP>:1985/rtc/v1/publish/
SRS_API_PASSWORD=changeMeSRS
SRS_WHEP_TOKEN_SECRET=your_whep_signing_secret
SRS_WHIP_TOKEN_SECRET=your_whip_signing_secret
SRS_WHEP_TOKEN_TTL_SECONDS=30

# Recording retention (days, 0 = keep forever)
RECORDING_RETENTION_DAYS=7

# CoTURN / STUN-TURN Server (WebRTC NAT traversal fallback)
# Shared secret for HMAC time-limited credential generation.
# Must match between Django and coturn. Generate with: openssl rand -base64 32
TURN_SHARED_SECRET=changeMeTurnSharedSecret
# Public IP or hostname of the coturn server (for ICE candidates).
# In production, set to the server's public IP. For local testing, use the LAN IP.
TURN_EXTERNAL_IP=192.168.100.91
# Realm for TURN authentication (should match turnserver.conf)
TURN_REALM=cvsentry.local
# UDP port range for TURN media relay (ensure host firewall allows this range)
TURN_MIN_PORT=49152
TURN_MAX_PORT=65535
# TTL for HMAC-generated TURN credentials (in seconds, default 86400 = 24h)
TURN_CREDENTIAL_TTL=86400
